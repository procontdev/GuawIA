    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  el.id,\n  el.created_at AS \"createdAt\",\n  COALESCE(el.contact_name, '') AS \"contactName\",\n  COALESCE(el.phone, '') AS phone,\n  COALESCE(el.attendee_count, 0) AS \"guestCount\",\n  el.event_date AS \"eventDate\",\n  COALESCE(el.location_text, '') AS location,\n  COALESCE(\n    el.event_type,\n    CASE\n      WHEN el.needs_food_service IS TRUE THEN 'Servicio de comida'\n      ELSE 'Evento'\n    END\n  ) AS \"chaufaChoice\",\n  COALESCE(el.notes, '') AS notes,\n  CASE\n    WHEN el.status = 'new' THEN 'nuevo'\n    WHEN el.status = 'qualified' THEN 'contactado'\n    WHEN el.status = 'quoted' THEN 'cotizado'\n    WHEN el.status IN ('won', 'lost', 'cancelled') THEN 'cerrado'\n    ELSE 'nuevo'\n  END AS status\nFROM guaw.event_leads el\nORDER BY el.created_at DESC\nLIMIT 100;",
        "options": {}
      },
