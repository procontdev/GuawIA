      "id": "cf6740d6-56d0-4aef-a959-ed140bda38a4",
      "name": "DashboardSummary - Webhook",
      "webhookId": "a651be6f-86ed-4742-8144-425490601e3f"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  (\n    SELECT COUNT(*)\n    FROM guaw.orders o\n    WHERE o.order_status IN ('pending_confirmation', 'confirmed', 'in_kitchen', 'dispatched')\n  ) AS \"activeOrders\",\n\n  (\n    SELECT COUNT(*)\n    FROM guaw.orders o\n    WHERE o.order_status IN ('pending_confirmation', 'confirmed')\n  ) AS \"newOrders\",\n\n  (\n    SELECT COUNT(*)\n    FROM guaw.orders o\n    WHERE o.order_status = 'in_kitchen'\n  ) AS \"preparingOrders\",\n\n  (\n    SELECT COUNT(*)\n    FROM guaw.orders o\n    WHERE o.order_status = 'dispatched'\n  ) AS \"readyOrders\",\n\n  (\n    SELECT COUNT(*)\n    FROM guaw.orders o\n    WHERE o.order_status = 'delivered'\n  ) AS \"deliveredOrders\",\n\n  (\n    SELECT COUNT(*)\n    FROM guaw.orders o\n    WHERE o.order_status IN ('pending_confirmation', 'confirmed', 'in_kitchen', 'dispatched', 'delivered')\n  ) AS \"todayOrders\",\n\n  COALESCE(\n    (\n      SELECT SUM(\n        COALESCE(\n          NULLIF(o.total_amount, 0),\n          (\n            COALESCE(\n              (\n                SELECT SUM(oi.line_subtotal)\n                FROM guaw.order_items oi\n                WHERE oi.order_id = o.id\n              ),\n              0\n            ) + COALESCE(o.delivery_fee, 0)\n          )\n        )\n      )\n      FROM guaw.orders o\n      WHERE o.order_status IN ('pending_confirmation', 'confirmed', 'in_kitchen', 'dispatched', 'delivered')\n    ),\n    0\n  )::float8 AS \"totalSalesAmount\",\n\n  COALESCE(\n    (\n      SELECT AVG(\n        COALESCE(\n          NULLIF(o.total_amount, 0),\n          (\n            COALESCE(\n              (\n                SELECT SUM(oi.line_subtotal)\n                FROM guaw.order_items oi\n                WHERE oi.order_id = o.id\n              ),\n              0\n            ) + COALESCE(o.delivery_fee, 0)\n          )\n        )\n      )\n      FROM guaw.orders o\n      WHERE o.order_status IN ('pending_confirmation', 'confirmed', 'in_kitchen', 'dispatched', 'delivered')\n    ),\n    0\n  )::float8 AS \"avgTicket\",\n\n  (\n    SELECT COUNT(*)\n    FROM guaw.event_leads el\n  ) AS \"eventLeads\",\n\n  (\n    SELECT COUNT(*)\n    FROM guaw.event_leads el\n    WHERE el.status IN ('new', 'qualified', 'quoted')\n  ) AS \"pendingEventLeads\",\n\n  (\n    SELECT COUNT(*)\n    FROM guaw.event_leads el\n    WHERE el.status = 'won'\n  ) AS \"closedEventLeads\";",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
