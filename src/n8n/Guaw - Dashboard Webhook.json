    {
      "parameters": {
        "jsCode": "const leadId = $json.body?.leadId;\nconst status = $json.body?.status;\n\nconst statusMap = {\n  nuevo: \"new\",\n  contactado: \"qualified\",\n  cotizado: \"quoted\",\n  cerrado: \"won\",\n};\n\nreturn [\n  {\n    json: {\n      leadId,\n      uiStatus: status,\n      dbStatus: statusMap[status] || \"new\",\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        144,
        416
      ],
      "id": "ddeb5372-ca50-405f-afc3-fefd0b14a968",
      "name": "Map DB Events"
    },
    {
      "parameters": {
        "jsCode": "const orderId = $json.body?.orderId;\nconst status = $json.body?.status;\n\nconst statusMap = {\n  nuevo: \"confirmed\",\n  preparacion: \"in_kitchen\",\n  listo: \"dispatched\",\n  entregado: \"delivered\",\n};\n\nreturn [\n  {\n    json: {\n      orderId,\n      uiStatus: status,\n      dbStatus: statusMap[status] || \"confirmed\",\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
