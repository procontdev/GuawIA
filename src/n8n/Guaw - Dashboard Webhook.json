{
  "name": "Guaw - Dashboard Webhook",
  "nodes": [
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  o.id,\n  'GW-' || upper(left(replace(o.id::text, '-', ''), 8)) AS code,\n  CASE\n    WHEN o.order_status IN ('pending_confirmation', 'confirmed') THEN 'nuevo'\n    WHEN o.order_status = 'in_kitchen' THEN 'preparacion'\n    WHEN o.order_status = 'dispatched' THEN 'listo'\n    WHEN o.order_status = 'delivered' THEN 'entregado'\n    ELSE 'nuevo'\n  END AS status,\n  COALESCE(o.confirmed_at, o.requested_at, o.created_at) AS \"createdAt\",\n  COALESCE(o.estimated_minutes_max, o.estimated_minutes_min, 45) AS \"etaMin\",\n  COALESCE(c.full_name, '') AS \"customerName\",\n  COALESCE(c.phone, '') AS phone,\n  COALESCE(o.district, '') AS district,\n  COALESCE(o.address_text, '') AS address,\n  COALESCE(o.reference_text, '') AS reference,\n\n  COALESCE(o.delivery_fee, 0)::float8 AS \"deliveryFee\",\n\n  COALESCE(\n    NULLIF(o.total_amount, 0),\n    (\n      COALESCE(\n        (\n          SELECT SUM(oi.line_subtotal)\n          FROM guaw.order_items oi\n          WHERE oi.order_id = o.id\n        ),\n        0\n      )\n      +\n      COALESCE(o.delivery_fee, 0)\n    )\n  )::float8 AS total,\n\n  COALESCE(o.customer_notes, o.internal_notes, '') AS notes,\n\n  COALESCE(\n    (\n      SELECT json_agg(\n        json_build_object(\n          'name', oi.item_name_snapshot,\n          'qty', oi.quantity,\n          'extras',\n            COALESCE(\n              (\n                SELECT json_agg(oie.extra_name ORDER BY oie.created_at)\n                FROM guaw.order_item_extras oie\n                WHERE oie.order_item_id = oi.id\n              ),\n              '[]'::json\n            )\n        )\n        ORDER BY oi.created_at\n      )\n      FROM guaw.order_items oi\n      WHERE oi.order_id = o.id\n    ),\n    '[]'::json\n  ) AS items\n\nFROM guaw.orders o\nLEFT JOIN guaw.customers c\n  ON c.id = o.customer_id\nWHERE o.order_status IN (\n  'pending_confirmation',\n  'confirmed',\n  'in_kitchen',\n  'dispatched',\n  'delivered'\n)\nORDER BY COALESCE(o.confirmed_at, o.requested_at, o.created_at) DESC\nLIMIT 100;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        144,
        -160
      ],
      "id": "1f315e49-c29b-42c5-9f50-19302345b1a5",
