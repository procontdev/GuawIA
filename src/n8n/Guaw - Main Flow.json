        "operation": "executeQuery",
        "query": "insert into guaw.customers (\n  full_name,\n  phone,\n  email,\n  channel,\n  external_user_id,\n  notes\n)\nvalues (\n  '{{ $json.full_name }}',\n  {{ $json.phone ? \"'\" + $json.phone.replace(/'/g, \"''\") + \"'\" : 'null' }},\n  {{ $json.email ? \"'\" + $json.email.replace(/'/g, \"''\") + \"'\" : 'null' }},\n  '{{ $json.channel }}',\n  '{{ $json.external_user_id }}',\n  {{ $json.notes ? \"'\" + $json.notes.replace(/'/g, \"''\") + \"'\" : 'null' }}\n)\non conflict (channel, external_user_id)\ndo update set\n  full_name = excluded.full_name,\n  phone = coalesce(excluded.phone, guaw.customers.phone),\n  email = coalesce(excluded.email, guaw.customers.email),\n  notes = coalesce(excluded.notes, guaw.customers.notes),\n  updated_at = now()\nreturning *;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        -240,
        -96
      ],
      "id": "a1f2aaa3-3e49-4906-ad8b-9313fede5ada",
