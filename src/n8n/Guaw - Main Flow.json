    {
      "parameters": {
        "jsCode": "const currentFlow = $json.current_flow;\nconst currentStep = $json.current_step;\nconst messageText = ($node[\"Normalize Input\"].json[\"message_text\"] || '').trim().toLowerCase();\n\nconst terminalSteps = [\n  'start',\n  'completed',\n  'order_confirmed',\n  'event_lead_registered',\n  'cancelled'\n];\n\nconst resetWords = [\n  'hola',\n  'buenas',\n  'hello',\n  'hi',\n  'menu',\n  'menú',\n  'quiero ver la carta',\n  'atienden eventos',\n  'info de eventos',\n  'quiero cotizar un evento',\n  'eventos'\n];\n\nconst looksLikeFreshStart = resetWords.some(w => messageText.includes(w));\n\nconst hasPendingDeliveryStep =\n  currentFlow === 'delivery' &&\n  currentStep &&\n  !terminalSteps.includes(currentStep);\n\nconst hasPendingEventsStep =\n  currentFlow === 'events' &&\n  currentStep &&\n  !terminalSteps.includes(currentStep);\n\nlet routeMode = 'classify';\n\nif (!looksLikeFreshStart && hasPendingDeliveryStep) {\n  routeMode = 'delivery_context';\n} else if (!looksLikeFreshStart && hasPendingEventsStep) {\n  routeMode = 'events_context';\n}\n\nreturn [\n  {\n    json: {\n      ...$json,\n      route_mode: routeMode\n    }\n  }\n];"
      },
