        "promptType": "define",
        "text": "={{ $('Normalize Input').item.json.message_text }}",
        "options": {
          "systemMessage": "=Eres un clasificador de intención para el asistente virtual de Guaw.\n\nDebes analizar el mensaje del usuario y devolver únicamente JSON válido.\n\nIntenciones permitidas:\n- delivery_order\n- menu_request\n- event_info\n- event_lead\n- greeting\n- human_help\n- fallback\n\nReglas:\n- \"quiero pedir\", \"deseo ordenar\", \"me das un chaufa\", \"quiero delivery\", \"pedido\" y similares => delivery_order\n- \"muestrame la carta\", \"que tienen\", \"menu\" y similares => menu_request\n- \"atienden eventos\", \"cómo funciona el servicio para eventos\", \"qué incluyen para eventos\", \"cuánto cuesta para eventos\" y similares => event_info o event_lead\n- \"quiero cotizar un evento\", \"quiero registrar un evento\", \"necesito una propuesta para un evento\" y similares => event_lead\n- saludos simples => greeting\n- si pide hablar con alguien => human_help\n- si no está claro => fallback\n\nDevuelve exactamente este formato:\n{\n  \"intent\": \"delivery_order\",\n  \"confidence\": 0.95,\n  \"entities\": {\n    \"products\": [],\n    \"district\": null,\n    \"event_date\": null\n  }\n}\n\nNo agregues texto fuera del JSON."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3,
      "position": [
        1984,
        -32
      ],
      "id": "94512569-2364-4c80-9006-efc6e821f09a",
      "name": "Intent Clasiffier"
    },
    {
      "parameters": {
        "jsCode": "const raw = $json.output ?? '';\n\nlet parsed;\n\ntry {\n  parsed = JSON.parse(raw);\n} catch (e) {\n  parsed = {\n    intent: 'fallback',\n    confidence: 0,\n    entities: {\n      products: [],\n      district: null,\n      event_date: null\n    }\n  };\n}\n\nreturn [\n  {\n    json: parsed\n  }\n];"
      },
